# KyberBot Environment Variables
# Copy this to .env and fill in values

# ═══════════════════════════════════════════════════
# REQUIRED
# ═══════════════════════════════════════════════════

# OpenAI API key for embeddings (text-embedding-3-small)
# Cost: ~$0.02 per million tokens — negligible
OPENAI_API_KEY=

# ═══════════════════════════════════════════════════
# OPTIONAL — Claude SDK Mode
# ═══════════════════════════════════════════════════

# Anthropic API key (enables SDK mode for faster brain operations)
# If not set, falls back to claude CLI subprocess (subscription mode)
# ANTHROPIC_API_KEY=

# ═══════════════════════════════════════════════════
# OPTIONAL — Server
# ═══════════════════════════════════════════════════

# API token for brain REST API authentication
# If not set, API is open (development mode)
# KYBERBOT_API_TOKEN=

# ═══════════════════════════════════════════════════
# OPTIONAL — Services
# ═══════════════════════════════════════════════════

# ChromaDB URL (default: http://localhost:8001)
# Change if running ChromaDB on a different port
# CHROMA_URL=http://localhost:8001

# Git auto-sync interval in minutes (default: 5)
# COMMIT_INTERVAL_MINUTES=5

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# ═══════════════════════════════════════════════════
# OPTIONAL — Kybernesis Cloud Sync
# ═══════════════════════════════════════════════════

# Kybernesis API key for cloud memory sync
# KYBERNESIS_API_KEY=
